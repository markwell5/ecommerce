{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["Content-Type", "Authorization", "X-Correlation-Id"]
  },
  "ConnectionStrings": {
    "PaymentDb": "Host=localhost;Database=payment_db;Username=ecommerce;Password=ecommerce"
  },
  "StripeSettings": {
    "SecretKey": ""
  },
  "JwtSettings": {
    "Secret": "super-secret-key-that-should-be-at-least-32-characters-long!",
    "Issuer": "ecommerce",
    "Audience": "ecommerce"
  },
  "RateLimiting": {
    "Read": { "PermitLimit": 60, "WindowSeconds": 60, "SegmentsPerWindow": 6 },
    "Write": { "PermitLimit": 10, "WindowSeconds": 60, "SegmentsPerWindow": 6 }
  }
}
